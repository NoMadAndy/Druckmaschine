# =============================================================================
# Druckmaschine - Environment Configuration
# =============================================================================
# Copy this file to .env and adjust values for your environment.
#   cp .env.example .env

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Username for the PostgreSQL database
DB_USER=druckmaschine

# Password for the PostgreSQL database
DB_PASSWORD=druckmaschine

# Database name
DB_NAME=druckmaschine

# Full async connection URL (used by backend; overrides individual DB_* vars)
DATABASE_URL=postgresql+asyncpg://druckmaschine:druckmaschine@db:5432/druckmaschine

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
# Redis connection URL for caching and pub/sub
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# Backend / Security
# -----------------------------------------------------------------------------
# Secret key for JWT token signing. MUST be changed in production.
SECRET_KEY=change-me-in-production

# Log level: debug, info, warning, error, critical
LOG_LEVEL=info

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# -----------------------------------------------------------------------------
# GPU / NVIDIA
# -----------------------------------------------------------------------------
# Enable GPU acceleration (true/false)
GPU_ENABLED=false

# Comma-separated list of GPU device IDs, or "all"
NVIDIA_VISIBLE_DEVICES=all

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
# Backend API URL as seen from the browser
VITE_API_URL=http://localhost:8000

# WebSocket URL as seen from the browser
VITE_WS_URL=ws://localhost:8000

# -----------------------------------------------------------------------------
# AI / LLM (optional, for agent system)
# -----------------------------------------------------------------------------
# OpenAI API key for GPT-based agents
# OPENAI_API_KEY=sk-...

# Anthropic API key for Claude-based agents
# ANTHROPIC_API_KEY=sk-ant-...

# -----------------------------------------------------------------------------
# Trading Module (optional)
# -----------------------------------------------------------------------------
# Starting virtual balance in EUR for simulation mode
TRADING_VIRTUAL_BALANCE=100.00

# Target balance in EUR for simulation mode
TRADING_TARGET_BALANCE=100000.00

# Enable real trading (requires explicit confirmation per trade)
TRADING_REAL_MODE=false
